{
  "contractVersion": "1.2.0",
  "service": "platform-api",
  "description": "Baseline API contract for the AI1 Platform command, query, streaming, and artifact boundary.",
  "protocol": "http-json",
  "apiVersion": "v1",
  "transportModes": ["http-json", "sse"],
  "storageArchitecture": {
    "relationalStore": "SQLite",
    "vectorStore": "ChromaDB",
    "artifactStore": "filesystem"
  },
  "principles": [
    "The platform API is the only public application boundary.",
    "The public boundary is separated into command, query, streaming, and artifact APIs.",
    "All workflows are started through typed commands.",
    "Agents are configured in advance and made available to workflows and agents through platform-managed registry data.",
    "Internal agent and workflow coordination is artifact-driven and not exposed directly to the UI.",
    "All write operations are auditable and return stable identifiers.",
    "Delivery-agent selection is driven by the task breakdown and may include one, two, or three of the current built-in delivery agents.",
    "Retriable mutations require idempotency keys.",
    "Live operational views consume streaming endpoints for status and log updates.",
    "SSE streaming is server-to-browser only and uses ordered, reconnect-aware event delivery.",
    "Streaming events use named event types and monotonically increasing sequence identifiers."
  ],
  "authorizationModel": {
    "mode": "role-and-capability",
    "roles": ["submitter", "reviewer", "operator", "admin"],
    "notes": [
      "All mutations must record actor identity.",
      "Approval endpoints may enforce no-self-approval policies when configured.",
      "Artifact access is authorized separately from metadata reads."
    ]
  },
  "resources": {
    "stories": {
      "create": {
        "method": "POST",
        "path": "/stories",
        "category": "command",
        "requiredHeaders": {
          "Idempotency-Key": { "type": "string", "minLength": 8 }
        },
        "requestBodySchema": {
          "type": "object",
          "required": [
            "title",
            "type",
            "narrative",
            "acceptanceCriteria",
            "priority"
          ],
          "properties": {
            "title": { "type": "string", "minLength": 1 },
            "type": { "type": "string", "enum": ["user-story", "technical-story"] },
            "narrative": { "type": "string", "minLength": 1 },
            "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
            "constraints": {
              "type": "array",
              "items": { "type": "string" }
            },
            "affectedModules": {
              "type": "array",
              "items": { "type": "string" }
            },
            "designReferences": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "type"],
                "properties": {
                  "name": { "type": "string" },
                  "type": { "type": "string", "enum": ["file", "url", "note"] },
                  "value": { "type": "string" }
                }
              }
            },
            "acceptanceCriteria": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["id", "given", "when", "then"],
                "properties": {
                  "id": { "type": "string" },
                  "given": { "type": "string" },
                  "when": { "type": "string" },
                  "then": { "type": "string" }
                }
              }
            }
          }
        },
        "responseBodySchema": {
          "type": "object",
          "required": ["storyId", "status", "createdAt"],
          "properties": {
            "storyId": { "type": "string" },
            "status": { "type": "string", "enum": ["draft", "submitted"] },
            "createdAt": { "type": "string", "format": "date-time" }
          }
        }
      },
      "get": {
        "method": "GET",
        "path": "/stories/{storyId}",
        "category": "query",
        "pathParams": {
          "storyId": { "type": "string" }
        },
        "responseBodySchema": {
          "$ref": "#/schemas/Story"
        }
      },
      "getDashboard": {
        "method": "GET",
        "path": "/stories/{storyId}/dashboard",
        "category": "query",
        "pathParams": {
          "storyId": { "type": "string" }
        },
        "responseBodySchema": {
          "$ref": "#/schemas/StoryDashboardView"
        }
      },
      "list": {
        "method": "GET",
        "path": "/stories",
        "category": "query",
        "queryParams": {
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "submitted",
              "decomposed",
              "architecture-pending-approval",
              "in-delivery",
              "validating",
              "in-review",
              "blocked",
              "completed",
              "rejected"
            ]
          },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          }
        },
        "responseBodySchema": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": { "$ref": "#/schemas/StorySummary" }
            }
          }
        }
      }
    },
    "artifacts": {
      "upload": {
        "method": "POST",
        "path": "/stories/{storyId}/artifacts",
        "category": "artifact",
        "requiredHeaders": {
          "Idempotency-Key": { "type": "string", "minLength": 8 }
        },
        "pathParams": {
          "storyId": { "type": "string" }
        },
        "requestBodySchema": {
          "type": "object",
          "required": ["artifactType", "name"],
          "properties": {
            "artifactType": {
              "type": "string",
              "enum": ["design-reference", "supporting-doc", "attachment", "evidence"]
            },
            "name": { "type": "string" },
            "contentType": { "type": "string" },
            "source": { "type": "string" }
          }
        },
        "responseBodySchema": {
          "$ref": "#/schemas/ArtifactReference"
        }
      },
      "getMetadata": {
        "method": "GET",
        "path": "/artifacts/{artifactId}",
        "category": "artifact",
        "pathParams": {
          "artifactId": { "type": "string" }
        },
        "responseBodySchema": {
          "$ref": "#/schemas/ArtifactReference"
        }
      },
      "download": {
        "method": "GET",
        "path": "/artifacts/{artifactId}/download",
        "category": "artifact",
        "pathParams": {
          "artifactId": { "type": "string" }
        },
        "responseBodySchema": {
          "$ref": "#/schemas/ArtifactDownload"
        }
      }
    },
    "workflows": {
      "decomposeStory": {
        "method": "POST",
        "path": "/stories/{storyId}/decompose",
        "category": "command",
        "requiredHeaders": {
          "Idempotency-Key": { "type": "string", "minLength": 8 }
        },
        "pathParams": {
          "storyId": { "type": "string" }
        },
        "requestBodySchema": {
          "type": "object",
          "properties": {
            "forceRestart": { "type": "boolean" }
          }
        },
        "responseBodySchema": {
          "$ref": "#/schemas/WorkflowStartResponse"
        }
      },
      "createArchitecture": {
        "method": "POST",
        "path": "/stories/{storyId}/architecture",
        "category": "command",
        "requiredHeaders": {
          "Idempotency-Key": { "type": "string", "minLength": 8 }
        },
        "pathParams": {
          "storyId": { "type": "string" }
        },
        "requestBodySchema": {
          "type": "object",
          "properties": {
            "decompositionRunId": { "type": "string" }
          }
        },
        "responseBodySchema": {
          "$ref": "#/schemas/WorkflowStartResponse"
        }
      },
      "startDelivery": {
        "method": "POST",
        "path": "/stories/{storyId}/delivery",
        "category": "command",
        "requiredHeaders": {
          "Idempotency-Key": { "type": "string", "minLength": 8 }
        },
        "pathParams": {
          "storyId": { "type": "string" }
        },
        "requestBodySchema": {
          "type": "object",
          "properties": {
            "architectureRunId": { "type": "string" },
            "agentSelection": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Optional override constrained to delivery agents approved by decomposition. If omitted, the platform uses the tasks-agent-recommended selection."
            }
          }
        },
        "responseBodySchema": {
          "$ref": "#/schemas/WorkflowStartResponse"
        }
      },
      "validateDelivery": {
        "method": "POST",
        "path": "/stories/{storyId}/validate",
        "category": "command",
        "requiredHeaders": {
          "Idempotency-Key": { "type": "string", "minLength": 8 }
        },
        "pathParams": {
          "storyId": { "type": "string" }
        },
        "requestBodySchema": {
          "type": "object",
          "properties": {
            "runIds": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "responseBodySchema": {
          "$ref": "#/schemas/WorkflowStartResponse"
        }
      }
    },
    "runs": {
      "get": {
        "method": "GET",
        "path": "/runs/{runId}",
        "category": "query",
        "pathParams": {
          "runId": { "type": "string" }
        },
        "responseBodySchema": {
          "$ref": "#/schemas/AgentRunResult"
        }
      },
      "listByStory": {
        "method": "GET",
        "path": "/stories/{storyId}/runs",
        "category": "query",
        "pathParams": {
          "storyId": { "type": "string" }
        },
        "responseBodySchema": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": { "$ref": "#/schemas/RunSummary" }
            }
          }
        }
      },
      "getLogs": {
        "method": "GET",
        "path": "/runs/{runId}/logs",
        "category": "query",
        "pathParams": {
          "runId": { "type": "string" }
        },
        "responseBodySchema": {
          "type": "object",
          "properties": {
            "entries": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "timestamp": { "type": "string", "format": "date-time" },
                  "level": { "type": "string" },
                  "message": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "streamLogs": {
        "method": "GET",
        "path": "/runs/{runId}/logs/stream",
        "category": "stream",
        "transport": "sse",
        "pathParams": {
          "runId": { "type": "string" }
        },
        "queryParams": {
          "afterSequence": { "type": "number" }
        },
        "responseBodySchema": {
          "$ref": "#/schemas/RunLogEvent"
        }
      },
      "streamEvents": {
        "method": "GET",
        "path": "/runs/{runId}/events",
        "category": "stream",
        "transport": "sse",
        "pathParams": {
          "runId": { "type": "string" }
        },
        "queryParams": {
          "afterSequence": { "type": "number" }
        },
        "responseBodySchema": {
          "$ref": "#/schemas/RunEvent"
        }
      },
      "getDiff": {
        "method": "GET",
        "path": "/runs/{runId}/diff",
        "category": "artifact",
        "pathParams": {
          "runId": { "type": "string" }
        },
        "responseBodySchema": {
          "type": "object",
          "properties": {
            "files": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": { "type": "string" },
                  "changeType": {
                    "type": "string",
                    "enum": ["added", "modified", "deleted", "renamed"]
                  },
                  "patchPath": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "reviews": {
      "list": {
        "method": "GET",
        "path": "/reviews",
        "category": "query",
        "queryParams": {
          "status": { "type": "string" },
          "stage": { "type": "string" }
        },
        "responseBodySchema": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": { "$ref": "#/schemas/ReviewDecision" }
            }
          }
        }
      },
      "get": {
        "method": "GET",
        "path": "/reviews/{reviewId}",
        "category": "query",
        "pathParams": {
          "reviewId": { "type": "string" }
        },
        "responseBodySchema": {
          "$ref": "#/schemas/ReviewDecision"
        }
      },
      "approve": {
        "method": "POST",
        "path": "/reviews/{reviewId}/approve",
        "category": "command",
        "requiredHeaders": {
          "Idempotency-Key": { "type": "string", "minLength": 8 },
          "If-Match-Version": { "type": "string", "minLength": 1 }
        },
        "pathParams": {
          "reviewId": { "type": "string" }
        },
        "requestBodySchema": {
          "type": "object",
          "required": ["decisionMaker"],
          "properties": {
            "decisionMaker": { "type": "string" },
            "comment": { "type": "string" }
          }
        },
        "responseBodySchema": {
          "$ref": "#/schemas/ReviewDecision"
        }
      },
      "requestRevision": {
        "method": "POST",
        "path": "/reviews/{reviewId}/request-revision",
        "category": "command",
        "requiredHeaders": {
          "Idempotency-Key": { "type": "string", "minLength": 8 },
          "If-Match-Version": { "type": "string", "minLength": 1 }
        },
        "pathParams": {
          "reviewId": { "type": "string" }
        },
        "requestBodySchema": {
          "type": "object",
          "required": ["decisionMaker", "reasons"],
          "properties": {
            "decisionMaker": { "type": "string" },
            "reasons": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        },
        "responseBodySchema": {
          "$ref": "#/schemas/ReviewDecision"
        }
      }
    },
    "traceability": {
      "getMatrix": {
        "method": "GET",
        "path": "/stories/{storyId}/traceability",
        "category": "query",
        "pathParams": {
          "storyId": { "type": "string" }
        },
        "responseBodySchema": {
          "type": "object",
          "properties": {
            "storyId": { "type": "string" },
            "links": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "acceptanceCriterionId": { "type": "string" },
                  "taskId": { "type": "string" },
                  "runId": { "type": "string" },
                  "artifactId": { "type": "string" },
                  "evidencePath": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  },
  "schemas": {
    "Story": {
      "type": "object",
      "required": ["storyId", "title", "type", "status", "acceptanceCriteria"],
      "properties": {
        "storyId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "submitted",
            "decomposed",
            "architecture-pending-approval",
            "in-delivery",
            "validating",
            "in-review",
            "blocked",
            "completed",
            "rejected"
          ]
        },
        "priority": { "type": "string" },
        "narrative": { "type": "string" },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "selectedAgentTypes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "acceptanceCriteria": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "given": { "type": "string" },
              "when": { "type": "string" },
              "then": { "type": "string" }
            }
          }
        }
      }
    },
    "StorySummary": {
      "type": "object",
      "properties": {
        "storyId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ArtifactReference": {
      "type": "object",
      "properties": {
        "artifactId": { "type": "string" },
        "artifactType": { "type": "string" },
        "path": { "type": "string" },
        "contentType": { "type": "string" },
        "sizeBytes": { "type": "number" },
        "integrityHash": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ArtifactDownload": {
      "type": "object",
      "properties": {
        "artifactId": { "type": "string" },
        "downloadUrl": { "type": "string" },
        "contentType": { "type": "string" },
        "sizeBytes": { "type": "number" },
        "integrityHash": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    },
    "WorkflowStartResponse": {
      "type": "object",
      "properties": {
        "workflowId": { "type": "string" },
        "runId": { "type": "string" },
        "status": { "type": "string", "enum": ["started", "already-running"] }
      }
    },
    "RunSummary": {
      "type": "object",
      "properties": {
        "runId": { "type": "string" },
        "workflowId": { "type": "string" },
        "agentType": { "type": "string" },
        "status": { "type": "string" },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    },
    "AgentRunResult": {
      "type": "object",
      "properties": {
        "runId": { "type": "string" },
        "storyId": { "type": "string" },
        "agentType": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["queued", "running", "blocked", "failed", "completed", "needs-review"]
        },
        "summary": { "type": "string" },
        "assumptions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/schemas/ArtifactReference" }
        },
        "changedFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "ReviewDecision": {
      "type": "object",
      "properties": {
        "reviewId": { "type": "string" },
        "version": { "type": "number" },
        "reviewStage": {
          "type": "string",
          "enum": ["clarification", "architecture", "delivery", "final-review"]
        },
        "status": {
          "type": "string",
          "enum": ["approved", "revision-requested", "rejected"]
        },
        "decisionMaker": { "type": "string" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "RunEvent": {
      "type": "object",
      "properties": {
        "sequence": { "type": "number" },
        "runId": { "type": "string" },
        "storyId": { "type": "string" },
        "eventType": {
          "type": "string",
          "enum": [
            "run.status",
            "workflow.status",
            "approval.changed",
            "validation.progress",
            "workflow.completed"
          ]
        },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "payload": { "type": "object" }
      }
    },
    "RunLogEvent": {
      "type": "object",
      "properties": {
        "sequence": { "type": "number" },
        "runId": { "type": "string" },
        "eventType": {
          "type": "string",
          "enum": ["run.log"]
        },
        "timestamp": { "type": "string", "format": "date-time" },
        "level": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "StoryDashboardView": {
      "type": "object",
      "properties": {
        "story": { "$ref": "#/schemas/Story" },
        "runs": {
          "type": "array",
          "items": { "$ref": "#/schemas/RunSummary" }
        },
        "pendingReviews": {
          "type": "array",
          "items": { "$ref": "#/schemas/ReviewDecision" }
        },
        "latestValidationStatus": { "type": "string" }
      }
    }
  },
  "internalContracts": {
    "AgentWorkItem": {
      "requiredFields": [
        "runId",
        "storyId",
        "agentType",
        "taskIds",
        "allowedTools",
        "inputArtifacts",
        "contextScope",
        "outputSchemaVersion",
        "policyConstraints"
      ]
    },
    "ValidationRequest": {
      "requiredFields": [
        "storyId",
        "runIds",
        "workspaceRefs",
        "checks"
      ]
    },
    "ReviewSignal": {
      "requiredFields": [
        "reviewId",
        "storyId",
        "decision",
        "decisionMaker"
      ]
    },
    "RunEventEnvelope": {
      "requiredFields": [
        "sequence",
        "runId",
        "eventType",
        "timestamp"
      ],
      "resumeMechanism": "Clients may resume from the last observed sequence using SSE reconnect semantics or explicit afterSequence query parameters."
    }
  }
}
